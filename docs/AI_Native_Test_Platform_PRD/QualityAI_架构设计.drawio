        <!-- Git 仓库目录结构 -->
        <mxCell id="git-tree" value="📁  Git 工程目录结构&#xa;&#xa;project-root/&#xa;├── requirements/          # 需求文档（Markdown）&#xa;├── tests/&#xa;│   ├── .qoder/           # Qoder CLI 配置&#xa;│   │   ├── config.yaml&#xa;│   │   ├── prompts/&#xa;│   │   └── agents/       # 自定义 Agent 扩展&#xa;│   ├── plans/            # 测试计划（Markdown）&#xa;│   ├── cases/            # 测试用例（Markdown）&#xa;│   ├── scripts/          # 测试脚本（Python）&#xa;│   ├── data/             # 测试数据（JSON/CSV）&#xa;│   ├── bugs/             # Bug 报告（Markdown）&#xa;│   └── reports/          # 执行报告（JSON/HTML）&#xa;├── .env.test             # 测试环境变量&#xa;└── pyproject.toml        # Python 项目配置" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9e7;strokeColor=#f39c12;fontSize=10;fontFamily=monospace;spacing=10;align=left;shadow=1;arcSize=10;" vertex="1" parent="1">
